<!doctype html>
<html lang="en" class="{{ pageClass }}" id="ffconf">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="source" content="https://github.com/IllyrianBrains">
    <link rel="preload" href="/assets/fonts/BasierSquare-Medium-custom.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/assets/fonts/BasierSquare-Regular-custom.woff2" as="font" type="font/woff2" crossorigin>
    <title>IB, komunitet i profesionisteve shqipfoles.</title>
    <link rel="stylesheet" href="/assets/css/base.css">
    {% if css %}
      {% if css.length %}
        {# css is treated as an array #}
        {% for stylesheet in css %}
          <link rel="stylesheet" href="/assets/css/{{ stylesheet }}">
        {% endfor %}
      {% else %}
        <link rel="stylesheet" href="/assets/css/{{ css }}">
      {% endif %}
    {% endif %}


    <link rel="stylesheet" href="/assets/css/mq.css">
    <link rel="alternate" type="application/rss+xml" title="Articles, news and community posts about FF Conf" href="/articles.xml">
    <meta name="description" content="Komuniteti i shqipfolesve."/>
    {%- include "favicons.njk" -%}
    {%- include "social.njk" %}
    <script defer async>
      const $$ = s => Array.from(document.querySelectorAll(s));
      const $ = s => document.querySelector(s);
    </script>
    <script defer data-domain="ffconf.org" src="https://plausible.io/js/script.outbound-links.js"></script>
<script>window.plausible = window.plausible || function() { (window.plausible.q = window.plausible.q || []).push(arguments) }</script>

    <!-- Leaflet CSS & JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  </head>
  <body id="{{ id }}">
    <a href="#main-content" class="skip">Skip to main content</a>
    <div class="body">
      {% include "header.njk" %}
      <main id="main-content" class="snap">
        {%- block content %}
        {{ content | safe }}
        {%- endblock %}
        {%- block credits %}
        {%- endblock %}
      </main>
      {% if not hide_newsletter %}
      {% include "newsletter.njk" %}
      {% endif %}
      <footer>
        <ul class="footer-links">
          <li><a href="/support/inclusion">Përfshirja</a></li>
          <li><a href="/support/code-of-conduct">Kodi i sjelljes</a></li>
          <li><a href="/support/contact">Contact Us</a></li>
          </ul>
        <div>
          <p>IllyrianBrains është një rrjet profesional nga persona me origjinë nga Shqipëria, Kosova, Maqedonia e Veriut, trevat dhe diaspora. Ne nuk 
          kemi përfitime monetare nga rrjeti, dhe nuk kemi ndërmend ta bëjmë këtë gjë në të ardhmen.
        </div>
      </footer>
    </div>

</body>
</html>


