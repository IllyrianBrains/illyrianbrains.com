---
layout: layouts/base.njk
css:
- photos.css
- history.css
- articles.css
---


<section class="history">
  <header>
    <h1><span id="count">Rrjeti</span></h1>
  </header>

  <div class="col">
  
    <div>
      <h2>Qytetet</h2>
      <p>
      Qytetet e IB janë hapësira ku lindin <b>mikro-komunitete</b>,
      të mbështetura nga anëtarët që ndajnë interesa dhe vlera të përbashkëta.
      Ato krijojnë hapësira miqësore për takime, bashkëbisedime dhe bashkëpunime, duke
      nxitur zhvillimin profesional në mënyrë të natyrshme dhe të afërt.

      <br><br>

      </p>

    </div>

    {% for slug, category in forum_posts %}
      {% if slug == 'Qytetet e reja' %}
        {% include "partials/forumTopics.njk" %}
      {% endif %}
    {% endfor %}
 
  </div>
</section>

<br><br>

<section class="history">
    <div class="container">
      {% include 'blocks/map_happyhours.njk' %}
    </div>
</section>
  
<br><br>
  


<section class="history">
  <div class="col">

    {% for slug, category in forum_posts %}
      {% if slug in ['Germanics', 'Western Europe' ] %}
        {% include "partials/forumTopics.njk" %}
      {% endif %}
    {% endfor %}

  </div>
  <br><br><br><br>
  <div class="col">

    {% for slug, category in forum_posts %}
      {% if slug in ['Northern Europe', 'Southern Europe'] %}
        {% include "partials/forumTopics.njk" %}
      {% endif %}
    {% endfor %}

  </div>
  
  <br><br><br><br>

  <div class="col">
    {% for slug, category in forum_posts %}
      {% if slug in ['North America'] %}
        {% include "partials/forumTopics.njk" %}
      {% endif %}
    {% endfor %}
  </div>
</section>



<br><br><br>

<section class="photos">
  <header class="with-filter">
    <h1><span id="count">Foto nga qytetet tona</span></h1>
  </header>

  <div id="photo-grid">
  {% for photo in photos | shuffle %}
  <div class="grid-item">
    <a target="_blank">
      <img loading="lazy" src="/assets/images/img/gallery-IB/{{ photo }}">
    </a>
  </div>
  {% endfor %}

  </div>
</section>
<script src="https://unpkg.com/macy@2.5.0/dist/macy.js"></script>
<script >
Macy({
    container: '#photo-grid',
    trueOrder: false,
    waitForImages: false,
    margin: 24,
    columns: 4,
    breakAt: {
        900: 2,
        420: 1,
    }
});</script>
